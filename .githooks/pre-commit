#!/usr/bin/env bash
set -euo pipefail

# Auto-regenerate committed derived artifacts when SKILL.md files change.
# index.yaml stays in sync automatically. Embeddings are local cache only.

REPO_ROOT="$(git rev-parse --show-toplevel)"

# --- /deliver state protection: block manual commits of agent-written files ---
# state.json and receipt.json under .spellbook/deliver/<ulid>/ are rewritten by
# /deliver itself and gitignored by default. If they appear in a commit, the
# user has either force-added them or bypassed the ignore. Almost always a
# mistake; surface loudly.
deliver_state_hits="$(
  git diff --cached --name-only --diff-filter=ACM |
    grep -E '^\.spellbook/deliver/.+/(state|receipt)\.json$' || true
)"
if [ -n "$deliver_state_hits" ]; then
  echo "[pre-commit] ERROR: refusing to commit agent-written /deliver state files:" >&2
  printf '  %s\n' "$deliver_state_hits" >&2
  echo "" >&2
  echo "These files are rewritten by /deliver and must never be human-edited." >&2
  echo "If /deliver is stuck, use:" >&2
  echo "  /deliver --resume <ulid>    # continue the in-flight run" >&2
  echo "  /deliver --abandon <ulid>   # clear state, keep branch" >&2
  exit 1
fi

skill_changed() {
  git diff --cached --name-only | grep -q 'skills/.*/SKILL\.md\|agents/.*\.md'
}

skill_changed || exit 0

# --- index.yaml: always regenerate (cheap, local) ---
echo "[pre-commit] Skill content changed — regenerating index.yaml"
bash "$REPO_ROOT/scripts/generate-index.sh" > /dev/null
git add "$REPO_ROOT/index.yaml"

echo "[pre-commit] Verifying shared-root install wording"
bash "$REPO_ROOT/scripts/check-harness-agnostic-installs.sh"

exit 0
