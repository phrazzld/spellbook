#!/usr/bin/env bash
# Pre-push hook: runs Dagger CI gates before allowing push.
# Installed by bootstrap.sh. Skips gracefully when Dagger or dagger.json absent.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

# Skip if no dagger.json in repo
[ -f "$repo_root/dagger.json" ] || exit 0

# Skip if dagger CLI not installed
if ! command -v dagger &>/dev/null; then
  echo "pre-push: dagger not installed, skipping CI gates" >&2
  exit 0
fi

# Skip if Docker/Colima not running
if ! docker info &>/dev/null 2>&1; then
  echo "pre-push: Docker not running, skipping CI gates" >&2
  exit 0
fi

echo "pre-push: running dagger call check..." >&2
if ! (cd "$repo_root" && dagger call check); then
  echo "pre-push: CI gates failed. Fix issues before pushing." >&2
  exit 1
fi
